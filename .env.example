OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TRAINING_MODEL=gpt-5.4-mini
OPENAI_SEARCH_MODEL=gpt-5.5
PORT=4317
RESPECT_ROBOTS_TXT=true
PARSER_USER_AGENT=WarsawSiteParser/1.0 local lead audit tool
MAX_ITEMS_PER_RUN=100
MAX_DISCOVERY_ITEMS=150
PARSER_PUBLIC_URL=https://parser.auraglobal-merchants.com

# Admin panel credentials (single admin account, separate from worker accounts
# created in the admin panel). Change these before deploying anywhere public.
ADMIN_LOGIN=admin
ADMIN_PASSWORD=Parol159


# Optional named Cloudflare Tunnel.
# Create a tunnel in Cloudflare and paste the token below, or point to a token file.
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_TOKEN_FILE=

# Optional registry integrations. Without these, use CSV import from CEIDG/REGON/KRS/catalog exports.
CEIDG_API_TOKEN=
CEIDG_API_ENDPOINT=https://dane.biznes.gov.pl/api/ceidg/v3/firmy
REGON_API_KEY=
GOOGLE_PLACES_API_KEY=
AWS_LOCATION_API_KEY=
AWS_LOCATION_REGION=eu-north-1
